{
  "name": "papazian-archive",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "npm run content:build && npm run assets:manifest && vite build && node --import tsx scripts/generate-static-shells.ts && npm run verify:build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts",
    "content:build": "node --import tsx scripts/build-content.ts",
    "content:scaffold": "node --import tsx scripts/scaffold-featured-projects.ts",
    "content:report": "node --import tsx scripts/content-report.ts",
    "images:prepare": "node --import tsx scripts/prepare-images.ts",
    "assets:manifest": "node --import tsx scripts/export-gallery.ts && node --import tsx scripts/build-media-manifest.ts",
    "verify:build": "node --import tsx scripts/validate-build.ts"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/three": "^0.184.1",
    "@vercel/analytics": "^2.0.1",
    "@vitejs/plugin-react": "^5.0.4",
    "gsap": "^3.15.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "three": "^0.184.0",
    "tone": "^15.1.22",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
